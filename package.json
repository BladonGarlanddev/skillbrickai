{
  "name": "skillbrickai",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @skillbrickai/web dev",
    "dev:api": "pnpm --filter @skillbrickai/api dev",
    "build": "pnpm -r build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:migrate": "pnpm --filter @skillbrickai/api prisma:migrate",
    "db:studio": "pnpm --filter @skillbrickai/api prisma:studio",
    "db:seed": "pnpm --filter @skillbrickai/api prisma:seed",
    "db:seed:all": "pnpm --filter @skillbrickai/api prisma:seed:all",
    "db:seed:prod": "pnpm --filter @skillbrickai/api prisma:seed:prod",
    "db:migrate:prod": "pnpm --filter @skillbrickai/api prisma:migrate:prod"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [

      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "@nestjs/core"
    ]
  }
}
