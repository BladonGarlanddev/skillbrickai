{
  "name": "collective",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @collective/web dev",
    "dev:api": "pnpm --filter @collective/api dev",
    "build": "pnpm -r build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:migrate": "pnpm --filter @collective/api prisma:migrate",
    "db:studio": "pnpm --filter @collective/api prisma:studio"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
