generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  username       String    @unique
  passwordHash   String?
  avatarUrl      String?
  bio            String?
  communityScore Int       @default(0)
  tokenBalance   Int       @default(0)
  isEarlyAdopter Boolean   @default(false)
  isBanned       Boolean   @default(false)
  banReason      String?
  githubId       String?   @unique
  googleId       String?   @unique
  createdAt      DateTime  @default(now())

  skills          Skill[]   @relation("authoredSkills")
  claimedSkills   Skill[]   @relation("claimedSkills")
  research        Research[] @relation("authoredResearch")
  claimedResearch Research[] @relation("claimedResearch")
  badges          Badge[]
  collections     Collection[]
  upvotes         Upvote[]
  tokenLedger     TokenTransaction[]
  posts           Post[]
  requests        SkillRequest[]
  showcases       Showcase[]
  suggestions     ImprovementSuggestion[]
  serviceOrders   ServiceOrder[]
}

model Skill {
  id           String   @id @default(cuid())
  name         String
  slug         String
  description  String
  content      String   @db.Text
  contentHash  String
  domain       String
  version      Int      @default(1)
  authorId     String
  installCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Attribution fields for externally sourced skills
  originalAuthorName String?
  originalAuthorUrl  String?
  sourceUrl          String?
  claimedById        String?
  claimedAt          DateTime?

  author       User     @relation("authoredSkills", fields: [authorId], references: [id])
  claimedBy    User?    @relation("claimedSkills", fields: [claimedById], references: [id])
  tags         SkillTag[]
  testedOn     SkillTestedOn[]
  upvotes      Upvote[]
  collections  CollectionSkill[]
  showcases    ShowcaseSkill[]
  suggestions  ImprovementSuggestion[]
  versions     SkillVersion[]

  @@unique([authorId, slug])
}

model Research {
  id             String   @id @default(cuid())
  name           String
  slug           String
  description    String
  content        String   @db.Text
  contentHash    String
  domain         String
  version        Int      @default(1)
  authorId       String
  referenceCount Int      @default(0)
  methodology    String?  @db.Text
  keyFindings    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Attribution fields for externally sourced research
  originalAuthorName String?
  originalAuthorUrl  String?
  sourceUrl          String?
  claimedById        String?
  claimedAt          DateTime?

  author      User     @relation("authoredResearch", fields: [authorId], references: [id])
  claimedBy   User?    @relation("claimedResearch", fields: [claimedById], references: [id])
  tags        ResearchTag[]
  sources     ResearchSource[]
  collections CollectionResearch[]
  versions    ResearchVersion[]

  @@unique([authorId, slug])
}

model ResearchVersion {
  id          String   @id @default(cuid())
  researchId  String
  version     Int
  content     String   @db.Text
  contentHash String
  createdAt   DateTime @default(now())

  research    Research @relation(fields: [researchId], references: [id], onDelete: Cascade)

  @@unique([researchId, version])
}

model ResearchTag {
  researchId String
  tag        String

  research   Research @relation(fields: [researchId], references: [id], onDelete: Cascade)

  @@id([researchId, tag])
}

model ResearchSource {
  id          String  @id @default(cuid())
  researchId  String
  title       String
  url         String?
  description String?

  research    Research @relation(fields: [researchId], references: [id], onDelete: Cascade)
}

model SkillVersion {
  id          String   @id @default(cuid())
  skillId     String
  version     Int
  content     String   @db.Text
  contentHash String
  createdAt   DateTime @default(now())

  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, version])
}

model SkillTag {
  skillId String
  tag     String

  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([skillId, tag])
}

model SkillTestedOn {
  skillId String
  model   String

  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([skillId, model])
}

model Badge {
  id        String    @id @default(cuid())
  userId    String
  type      BadgeType
  earnedAt  DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

enum BadgeType {
  EARLY_ADOPTER
  CONTRIBUTOR
  ACTIVE_COMMUNITY_MEMBER
  MR_POPULAR
  CURATOR
  HELPER
  VERIFIED_EXPERT
  RESEARCHER
}

model TokenTransaction {
  id        String            @id @default(cuid())
  userId    String
  amount    Int
  type      TokenTransactionType
  skillId   String?
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id])
}

enum TokenTransactionType {
  ACCOUNT_CREATED
  SKILL_POSTED
  SKILL_INSTALLED
  ADMIN_GRANT
  RESEARCH_POSTED
}

model Upvote {
  id         String       @id @default(cuid())
  userId     String
  targetType UpvoteTarget
  targetId   String
  createdAt  DateTime     @default(now())

  user       User         @relation(fields: [userId], references: [id])
  skill      Skill?       @relation(fields: [targetId], references: [id])

  @@unique([userId, targetType, targetId])
}

enum UpvoteTarget {
  SKILL
  POST
  REPLY
  SHOWCASE
  RESEARCH
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  authorId    String
  createdAt   DateTime @default(now())

  author         User     @relation(fields: [authorId], references: [id])
  skills         CollectionSkill[]
  researchItems  CollectionResearch[]
}

model CollectionSkill {
  collectionId String
  skillId      String
  addedAt      DateTime @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  skill        Skill      @relation(fields: [skillId], references: [id])

  @@id([collectionId, skillId])
}

model CollectionResearch {
  collectionId String
  researchId   String
  addedAt      DateTime @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  research     Research   @relation(fields: [researchId], references: [id])

  @@id([collectionId, researchId])
}

model Post {
  id        String       @id @default(cuid())
  title     String?
  body      String       @db.Text
  authorId  String
  category  PostCategory
  parentId  String?
  createdAt DateTime     @default(now())

  author    User         @relation(fields: [authorId], references: [id])
  parent    Post?        @relation("replies", fields: [parentId], references: [id])
  replies   Post[]       @relation("replies")
}

enum PostCategory {
  GENERAL
  HELP
  IDEAS
  SHOW_AND_TELL
}

model SkillRequest {
  id          String              @id @default(cuid())
  title       String
  description String              @db.Text
  authorId    String
  status      SkillRequestStatus  @default(OPEN)
  createdAt   DateTime            @default(now())

  author      User                @relation(fields: [authorId], references: [id])
  replies     SkillRequestReply[]
}

enum SkillRequestStatus {
  OPEN
  FULFILLED
}

model SkillRequestReply {
  id         String       @id @default(cuid())
  requestId  String
  authorId   String
  body       String       @db.Text
  skillId    String?
  createdAt  DateTime     @default(now())

  request    SkillRequest @relation(fields: [requestId], references: [id])
}

model Showcase {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  authorId    String
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])
  skills      ShowcaseSkill[]
}

model ShowcaseSkill {
  showcaseId String
  skillId    String

  showcase   Showcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id])

  @@id([showcaseId, skillId])
}

model ImprovementSuggestion {
  id              String           @id @default(cuid())
  skillId         String
  authorId        String
  proposedContent String           @db.Text
  note            String?
  status          SuggestionStatus @default(PENDING)
  createdAt       DateTime         @default(now())

  skill           Skill            @relation(fields: [skillId], references: [id])
  author          User             @relation(fields: [authorId], references: [id])
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Service {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String        @db.Text
  longDescription String?   @db.Text
  price       Int           // Price in cents (e.g., 4999 = $49.99)
  currency    String        @default("usd")
  pricingType ServicePricingType @default(ONE_TIME)
  category    String
  features    String[]
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orders      ServiceOrder[]
}

model ServiceOrder {
  id          String             @id @default(cuid())
  serviceId   String
  userId      String
  status      ServiceOrderStatus @default(PENDING)
  notes       String?            @db.Text
  deliveryUrl String?
  paidAmount  Int                // Amount paid in cents
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  service     Service            @relation(fields: [serviceId], references: [id])
  user        User               @relation(fields: [userId], references: [id])
}

enum ServicePricingType {
  ONE_TIME
  RECURRING_MONTHLY
  RECURRING_YEARLY
}

enum ServiceOrderStatus {
  PENDING
  PAID
  IN_PROGRESS
  DELIVERED
  CANCELLED
  REFUNDED
}
